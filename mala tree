            justify-content: center;
            margin: 24px 0;
            position: relative;
        }
        .lotus-separator::before, .lotus-separator::after {
            content: '';
            height: 1px;
            width: 80px;
            background: linear-gradient(to right, transparent, var(--primary));
        }
        .lotus-separator::after {
            background: linear-gradient(to left, transparent, var(--primary));
        }
        .lotus-separator span {
            font-size: 1.8rem;
            color: var(--primary);
            margin: 0 16px;
            line-height: 1;
        }

        /* Section Header Layout */

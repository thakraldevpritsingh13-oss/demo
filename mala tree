    <style>
        /* ==========================================================================
           COLOR SYSTEM & VARIABLES
           ========================================================================== */
        :root {
            --primary: #8B5E3C;
            --cream: #F8F4EE;
            --saffron: #D4860B;
            --green: #3B5323;
            --white: #FFFFFF;
            --dark: #2B2118;
            --text: #4A3A2F;
            --transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);

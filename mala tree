            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Nunito', sans-serif;
            color: var(--text);
            background-color: var(--cream);
            line-height: 1.7;
            overflow-x: hidden;

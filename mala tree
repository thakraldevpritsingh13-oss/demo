            transition: opacity 0.8s ease, transform 0.8s ease;
        }
        .fade-up.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Focus States for Accessibility */
        *:focus-visible {
            outline: 3px solid var(--saffron);
            outline-offset: 3px;
        }

        /* Button Ripple Setup */
        .btn {
